buildCommand: make install
buildDir: build
cursorMovement: 1
devMode: 0
excludeDirs: build*
formatCommand: clang-format -i %f
formatScope: 1
indexDirs: doomsday/*/src;doomsday/*/include
indicators: 0
lineEndings: 0
maxLineWidth: 100
lineNumbers: 1
otherDirs: 
runCommand: 
showHidden: 0
softWrap: 1
softTabs: 1
splitRatio: 50
syntaxHighlight: 1
tabIndent: 1
tabSize: 4
trimLinesOnSave: 1
catalogPath: 
searchMode: 0
autoIndent: 1
